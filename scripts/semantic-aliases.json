{
  "$schema-comment": "Maps Synapse DESIGN.md semantic slots to Tailwind palette references (palette.shade) and font-size scales. Edit this file to retune; sync-from-source.mjs reads it to regenerate templates/DESIGN.md.",
  "version": 1,
  "source": "synapse-workspace/lib/tailwind/theme + components/ui/button",
  "colors": {
    "ink": "slate.900",
    "muted": "slate.500",
    "border": "slate.300",
    "surface": "white.950",
    "surfaceSubtle": "slate.50",
    "accent": "blue.600",
    "accentHover": "blue.700",
    "accentActive": "blue.800",
    "success": "green.500",
    "warning": "yellow.500",
    "danger": "red.600"
  },
  "typography": {
    "headline-lg": "3xl",
    "headline-md": "2xl",
    "title-sm": "base",
    "body-md": "sm",
    "label-sm": "xs"
  },
  "$sizes-comment": "Derived from frequency analysis of arbitrary tailwind values in synapse-workspace (see evidence/eval-*.json). Values appearing >=4 times across components+pages were promoted to semantic slots. Edit names freely; sync-from-source.mjs emits these verbatim under `sizes:`.",
  "sizes": {
    "actionMin": "6.125rem",
    "controlHeight": "32px",
    "modalBody": "45rem",
    "modalHeight": "40rem",
    "modalMaxHeight": "50rem",
    "dialogWide": "37.5rem",
    "formColumn": "13.75rem",
    "pageColumn": "21.375rem",
    "guideOffset": "7.5rem"
  },
  "fontFamily": "\"Pretendard Variable\", ui-sans-serif, system-ui, sans-serif",
  "components": {
    "button-primary": {
      "source": "components/ui/button (variant=solid, color=blue)",
      "backgroundColor": "{colors.accent}",
      "hoverBackgroundColor": "{colors.accentHover}",
      "activeBackgroundColor": "{colors.accentActive}",
      "textColor": "{colors.surface}",
      "rounded": "{rounded.lg}",
      "paddingInline": "16px",
      "paddingBlock": "6px"
    },
    "button-tint": {
      "source": "components/ui/button (variant=tint, color=blue)",
      "backgroundColor": "blue.200",
      "textColor": "{colors.accent}",
      "rounded": "{rounded.lg}",
      "paddingInline": "16px",
      "paddingBlock": "6px"
    },
    "card": {
      "source": "components/ui/card defaults",
      "backgroundColor": "{colors.surface}",
      "borderColor": "{colors.border}",
      "rounded": "{rounded.lg}",
      "padding": "{spacing.xl}"
    },
    "input": {
      "source": "components/ui/* form controls",
      "backgroundColor": "{colors.surface}",
      "borderColor": "{colors.border}",
      "textColor": "{colors.ink}",
      "rounded": "{rounded.md}",
      "paddingInline": "{spacing.md}",
      "paddingBlock": "{spacing.sm}"
    },
    "badge": {
      "source": "components/ui/badge (variant=tint default, color=slate)",
      "backgroundColor": "slate.100",
      "textColor": "slate.600",
      "rounded": "{rounded.md}",
      "paddingInline": "{spacing.sm}",
      "paddingBlock": "2px",
      "typography": "{typography.label-sm}"
    },
    "alert": {
      "source": "components/ui/alert (defaultVariants color=slate, padding=md)",
      "backgroundColor": "slate.100",
      "textColor": "slate.600",
      "paddingInline": "48px",
      "paddingBlock": "{spacing.md}"
    },
    "dialog": {
      "source": "components/ui/dialog (DialogContent base, size=md default). maxWidth mirrors sizes.modalBody (45rem); maxHeight uses dvh viewport unit.",
      "backgroundColor": "{colors.surface}",
      "rounded": "{rounded.xl}",
      "maxWidth": "45rem",
      "maxHeight": "90dvh",
      "shadow": "lg"
    },
    "table-row": {
      "source": "components/ui/table (tableRowVariants, isHeader=false default)",
      "height": "64px",
      "borderColor": "slate.200",
      "selectedBackgroundColor": "blue.100",
      "errorBackgroundColor": "red.100",
      "disabledBackgroundColor": "slate.100"
    },
    "table-header-row": {
      "source": "components/ui/table (tableRowVariants, isHeader=true)",
      "backgroundColor": "{colors.surfaceSubtle}",
      "height": "40px",
      "borderColor": "slate.300",
      "textColor": "slate.600",
      "typography": "{typography.label-sm}"
    }
  }
}
