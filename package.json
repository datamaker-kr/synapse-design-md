{
  "name": "synapse-design-md",
  "version": "0.5.0",
  "description": "Synapse DESIGN.md contract installer, updater, and evaluator.",
  "type": "module",
  "bin": {
    "synapse-design-md": "./bin/synapse-design-md.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "templates/",
    "eval/",
    "examples/",
    "fixtures/anonymized/",
    "golden/",
    "README.md"
  ],
  "scripts": {
    "check": "node ./bin/synapse-design-md.js check",
    "doctor": "node ./bin/synapse-design-md.js doctor",
    "install:local": "node ./bin/synapse-design-md.js install",
    "test": "node --test scripts/test.mjs",
    "verify:colors": "node scripts/verify-colors.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
